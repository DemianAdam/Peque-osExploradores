{
  "name": "peque-osexploradores",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "convex dev --start \"vite --open\"",
    "predev": "convex init && node setup.mjs --once",
    "serve": "powershell -NoProfile -ExecutionPolicy Bypass -File serve.ps1",
    "build": "tsc -b && vite build",
    "lint": "tsc && eslint .  --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview"
  },
  "dependencies": {
    "@convex-dev/auth": "^0.0.91",
    "@convex-dev/sharded-counter": "^0.2.1",
    "convex": "^1.36.1",
    "convex-helpers": "^0.1.112",
    "lucia": "^3.2.2",
    "lucide-react": "^1.23.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router": "^8.0.1",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@convex-dev/eslint-plugin": "^2.0.0",
    "@eslint/js": "^9.39.4",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "dotenv": "^17.4.2",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.9"
  }
}
